#:import dp kivy.metrics.dp

<ChatScreen>:
    orientation: "horizontal"
    canvas.after:
        Color:
            rgba: root.theme_ripple_color[0], root.theme_ripple_color[1], root.theme_ripple_color[2], root.theme_ripple_opacity
        Ellipse:
            pos: root.theme_ripple_center[0] - root.theme_ripple_radius, root.theme_ripple_center[1] - root.theme_ripple_radius
            size: root.theme_ripple_radius * 2, root.theme_ripple_radius * 2

    # Sidebar
    BoxLayout:
        orientation: "vertical"
        size_hint_x: None
        width: dp(272)
        padding: dp(18), dp(20)
        spacing: dp(9)

        canvas.before:
            Color:
                rgba: (0.055, 0.075, 0.12, 1) if root.dark_mode else (0.94, 0.96, 0.99, 1)
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: (0.16, 0.23, 0.34, 1) if root.dark_mode else (0.80, 0.85, 0.92, 1)
            Rectangle:
                pos: self.right - dp(1), self.y
                size: dp(1), self.height

        Label:
            text: "API Assistant"
            font_size: "23sp"
            bold: True
            color: (0.94, 0.97, 1, 1) if root.dark_mode else (0.08, 0.13, 0.22, 1)
            size_hint_y: None
            height: dp(44)
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: "YOUR SMART WORKSPACE"
            font_size: "10sp"
            color: (0.48, 0.62, 0.78, 1) if root.dark_mode else (0.27, 0.42, 0.62, 1)
            size_hint_y: None
            height: dp(23)
            halign: "left"
            valign: "middle"
            text_size: self.size

        Button:
            id: new_chat_button
            text: "+   New chat"
            size_hint_y: None
            height: dp(46)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            font_size: "15sp"
            bold: True
            halign: "left"
            valign: "middle"
            text_size: self.width - dp(28), self.height
            on_release: root.new_chat()
            canvas.before:
                Color:
                    rgba: (0.12, 0.43, 0.91, 1) if self.state == "normal" else (0.09, 0.34, 0.75, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]

        Widget:
            size_hint_y: None
            height: dp(12)

        ThemedNavButton:
            text: "Main Chat"
            dark_mode: root.dark_mode
            size_hint_y: None
            height: dp(42)

        Label:
            text: "EXPLORE"
            font_size: "10sp"
            bold: True
            color: (0.45, 0.55, 0.68, 1) if root.dark_mode else (0.35, 0.46, 0.61, 1)
            size_hint_y: None
            height: dp(23)
            halign: "left"
            valign: "middle"
            text_size: self.size

        ThemedNavButton:
            text: "⌂   Home"
            dark_mode: root.dark_mode
        ThemedNavButton:
            text: "☀   Weather"
            dark_mode: root.dark_mode
        ThemedNavButton:
            text: "▤   News"
            dark_mode: root.dark_mode
        ThemedNavButton:
            text: "¤   Currency"
            dark_mode: root.dark_mode
        ThemedNavButton:
            text: "✎   Dictionary"
            dark_mode: root.dark_mode
        ThemedNavButton:
            text: "◌   NASA"
            dark_mode: root.dark_mode
        ThemedNavButton:
            text: "⚑   Countries"
            dark_mode: root.dark_mode
        ThemedNavButton:
            text: "☺   Jokes"
            dark_mode: root.dark_mode

        Widget:

        ThemedNavButton:
            text: "⚙   Settings"
            dark_mode: root.dark_mode
            size_hint_y: None
            height: dp(42)

        ThemedNavButton:
            text: "☀   Light Mode" if root.dark_mode else "☾   Dark Mode"
            dark_mode: root.dark_mode
            size_hint_y: None
            height: dp(42)
            on_release: root.start_theme_transition(self.center)

    # Main panel
    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: (0.075, 0.10, 0.16, 1) if root.dark_mode else (0.975, 0.985, 1, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        # Header
        BoxLayout:
            size_hint_y: None
            height: dp(76)
            padding: dp(38), 0
            canvas.before:
                Color:
                    rgba: (0.07, 0.095, 0.15, 1) if root.dark_mode else (1, 1, 1, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: (0.16, 0.23, 0.34, 1) if root.dark_mode else (0.82, 0.87, 0.94, 1)
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, dp(1)

            Label:
                text: root.page_title.split("\\n")[0]
                font_size: "22sp"
                bold: True
                color: (0.94, 0.97, 1, 1) if root.dark_mode else (0.08, 0.13, 0.22, 1)
                halign: "left"
                valign: "middle"
                text_size: self.size

            Label:
                text: "◐  Theme"
                font_size: "13sp"
                font_name: "C:/Windows/Fonts/seguisym.ttf"
                color: (0.46, 0.78, 0.62, 1) if root.dark_mode else (0.12, 0.53, 0.32, 1)
                size_hint_x: None
                width: dp(70)
                halign: "right"
                valign: "middle"
                text_size: self.size

        # Welcome content
        BoxLayout:
            orientation: "vertical"
            padding: dp(64), dp(52)
            spacing: dp(14)

            Widget:
                size_hint_y: 0.45

            Label:
                text: root.page_title
                font_size: "38sp"
                bold: True
                color: (0.95, 0.97, 1, 1) if root.dark_mode else (0.08, 0.13, 0.22, 1)
                size_hint_y: None
                height: dp(104)
                halign: "center"
                valign: "middle"
                text_size: self.width, self.height

            Label:
                text: root.page_subtitle
                color: (0.66, 0.73, 0.84, 1) if root.dark_mode else (0.29, 0.37, 0.49, 1)
                font_size: "17sp"
                size_hint_y: None
                height: dp(28)
                halign: "center"
                valign: "middle"
                text_size: self.size

            BoxLayout:
                size_hint_y: None
                height: dp(34) if root.is_loading else 0
                padding: dp(12), 0
                canvas.before:
                    Color:
                        rgba: 0.13, 0.42, 0.88, 1 if root.is_loading else 0
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]

                Label:
                    text: "API Assistant is typing" + "." * int(root.typing_dots)
                    color: 1, 1, 1, 1
                    font_size: "13sp"
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

            Label:
                text: root.response_text
                color: (0.47, 0.57, 0.70, 1) if root.dark_mode else (0.42, 0.49, 0.60, 1)
                font_size: "15sp"
                size_hint_y: None
                height: min(self.texture_size[1] + dp(8), dp(180))
                halign: "left"
                valign: "top"
                text_size: self.width, None

            Widget:
                size_hint_y: 0.55

        # Composer
        BoxLayout:
            size_hint_y: None
            height: dp(88)
            padding: dp(32), dp(16)
            spacing: dp(12)
            canvas.before:
                Color:
                    rgba: (0.07, 0.095, 0.15, 1) if root.dark_mode else (1, 1, 1, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: (0.16, 0.23, 0.34, 1) if root.dark_mode else (0.82, 0.87, 0.94, 1)
                Rectangle:
                    pos: self.x, self.top - dp(1)
                    size: self.width, dp(1)

            ChatInput:
                id: query_input
                multiline: False
                hint_text: "Type a weather question, e.g. What is the weather in Tokyo?"
                focus: True
                font_size: "16sp"
                background_normal: ""
                background_active: ""
                background_color: 0, 0, 0, 0
                foreground_color: (0.93, 0.96, 1, 1) if root.dark_mode else (0.10, 0.15, 0.23, 1)
                hint_text_color: (0.44, 0.54, 0.67, 1) if root.dark_mode else (0.43, 0.50, 0.62, 1)
                cursor_color: 0, 0, 0, 0
                cursor_width: dp(2.5)
                padding: dp(17), dp(13)
                on_text_validate: root.send_query()
                canvas.before:
                    Color:
                        rgba: (0.10, 0.145, 0.22, 1) if root.dark_mode else (0.95, 0.97, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(14)]
                    Color:
                        rgba: (0.24, 0.55, 0.98, 1) if self.focus else ((0.18, 0.27, 0.40, 1) if root.dark_mode else (0.75, 0.81, 0.90, 1))
                    Line:
                        rounded_rectangle: (self.x, self.y, self.width, self.height, dp(14))
                        width: dp(1)
                canvas.after:
                    Color:
                        rgba: 0.08, 0.40, 0.92, 1 if self.focus and self.caret_visible else 0
                    Rectangle:
                        pos: self.cursor_pos[0], self.cursor_pos[1] - self.line_height
                        size: dp(2.5), self.line_height

            Button:
                text: u"\u27A4"
                size_hint_x: None
                width: dp(58)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                font_size: "20sp"
                bold: True
                halign: "center"
                valign: "middle"
                text_size: self.size
                on_release: root.send_query()
                canvas.before:
                    Color:
                        rgba: (0.13, 0.42, 0.88, 1) if self.state == "normal" else (0.09, 0.32, 0.70, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]

<Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.73, 0.80, 0.90, 1
    font_size: "15sp"
    font_name: "C:/Windows/Fonts/seguisym.ttf"
    halign: "left"
    valign: "middle"
    text_size: self.width - dp(28), self.height

<ThemedNavButton>:
    color: (0.73, 0.80, 0.90, 1) if self.dark_mode else (0.18, 0.27, 0.40, 1)
    canvas.before:
        Color:
            rgba: (0.12, 0.19, 0.30, 1) if self.dark_mode and self.state == "down" else (0.085, 0.125, 0.19, 1) if self.dark_mode else (0.82, 0.87, 0.94, 1) if self.state == "down" else (0.90, 0.94, 0.99, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]
