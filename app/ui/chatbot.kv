#:import dp kivy.metrics.dp
#:import Sidebar app.widgets.sidebar.Sidebar

<ChatScreen>

    orientation: "horizontal"

    Sidebar:

    BoxLayout:

        orientation: "vertical"

        canvas.before:
            Color:
                rgba:0.13,0.13,0.15,1
            Rectangle:
                pos:self.pos
                size:self.size

        ####################################################
        ## Header
        ####################################################

        BoxLayout:

            size_hint_y: None

            height: dp(60)

            padding: dp(20),0

            canvas.before:
                Color:
                    rgba:0.10,0.10,0.12,1
                Rectangle:
                    pos:self.pos
                    size:self.size

            Label:

                text:"Welcome"

                color:1,1,1,1

                font_size:"22sp"

                bold:True

        ####################################################
        ## Chat Area
        ####################################################

        BoxLayout:

            orientation:"vertical"

            padding:dp(40)

            spacing:dp(15)

            Label:

                text:"Welcome to API Assistant"

                font_size:"32sp"

                bold:True

                color:1,1,1,1

                size_hint_y:None

                height:self.texture_size[1]

            Label:

                text:"Your all-in-one API desktop assistant."

                color:.7,.7,.75,1

                font_size:"18sp"

                size_hint_y:None

                height:self.texture_size[1]

            Widget:

        ####################################################
        ## Bottom Input
        ####################################################

        BoxLayout:

            size_hint_y:None

            height:dp(80)

            padding:dp(15)

            spacing:dp(10)

            canvas.before:
                Color:
                    rgba:.10,.10,.12,1
                Rectangle:
                    pos:self.pos
                    size:self.size

            TextInput:

                hint_text:"Ask me anything..."

                multiline:False

            Button:

                text:"Send"

                size_hint_x:None

                width:dp(120)